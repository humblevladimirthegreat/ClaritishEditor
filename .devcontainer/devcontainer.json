{
  "name": "Claritish Editor",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "postCreateCommand": "npm install",
  "forwardPorts": [5500],
  "portsAttributes": {
    "5500": {
      "label": "Live Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mkaufman.HTMLHint",
        "ritwickdey.LiveServer"
      ],
      "settings": {
        "htmlhint.enable": true,
        "liveServer.settings.root": "/workspaces/ClaritishEditor"
      }
    }
  }
}
